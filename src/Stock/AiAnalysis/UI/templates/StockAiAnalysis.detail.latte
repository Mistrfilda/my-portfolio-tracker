{templateType App\Stock\AiAnalysis\UI\StockAiAnalysisTemplate}

{block #content}
	<div class="mb-6">
		<a n:href="default" class="inline-flex items-center text-sm text-blue-600 hover:text-blue-800">
			← Zpět na přehled analýz
		</a>
	</div>

	{if $run !== null}
		<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
			<div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
				<div class="flex items-center justify-between">
					<h2 class="text-lg font-semibold text-gray-900">Informace o analýze</h2>
					<span class="text-sm text-gray-500">{$run->getCreatedAt()|datetimeFormat:App\Utils\Datetime\DatetimeConst::SYSTEM_DATETIME_FORMAT}</span>
				</div>
			</div>
			<div class="px-6 py-4">
				<div class="flex flex-wrap gap-3">
					<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium {if $run->includesPortfolio()}bg-blue-100 text-blue-800 ring-1 ring-inset ring-blue-200{else}bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-200{/if}">
						Portfolio: {if $run->includesPortfolio()}Ano{else}Ne{/if}
					</span>
					<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium {if $run->includesWatchlist()}bg-purple-100 text-purple-800 ring-1 ring-inset ring-purple-200{else}bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-200{/if}">
						Watchlist: {if $run->includesWatchlist()}Ano{else}Ne{/if}
					</span>
					<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium {if $run->includesMarketOverview()}bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-200{else}bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-200{/if}">
						Trhy: {if $run->includesMarketOverview()}Ano{else}Ne{/if}
					</span>
					{if $run->getPortfolioPromptType()}
						<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-cyan-100 text-cyan-800 ring-1 ring-inset ring-cyan-200">
							Typ: {$run->getPortfolioPromptType()->getLabel()}
						</span>
					{/if}
					{if $run->getProcessedAt()}
						<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-green-100 text-green-800 ring-1 ring-inset ring-green-200">
							✓ Zpracováno {$run->getProcessedAt()|datetimeFormat:App\Utils\Datetime\DatetimeConst::SYSTEM_DATETIME_FORMAT}
						</span>
					{else}
						<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 ring-1 ring-inset ring-yellow-200">
							⏳ Čeká na zpracování
						</span>
					{/if}
				</div>
			</div>
		</div>

		{* Vygenerovaný prompt *}
		<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
			<div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
				<h2 class="text-lg font-semibold text-gray-900">Vygenerovaný prompt</h2>
			</div>
			<div class="px-6 py-4">
				<div class="bg-gray-50 p-4 rounded-lg border border-gray-200 max-h-96 overflow-y-auto">
					<pre class="text-sm text-gray-800 whitespace-pre-wrap font-mono">{$run->getGeneratedPrompt()}</pre>
				</div>
 			<div class="mt-4">
					<button id="copy-prompt-btn" type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-xs text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-hidden transition-colors">
						Kopírovat do schránky
					</button>
				</div>
				<pre id="prompt-text" class="hidden">{$run->getGeneratedPrompt()}</pre>
				<script>
					document.getElementById('copy-prompt-btn').addEventListener('click', function () {
						var btn = this;
						var text = document.getElementById('prompt-text').textContent;
						if (navigator.clipboard && navigator.clipboard.writeText) {
							navigator.clipboard.writeText(text).then(function () {
								btn.textContent = '✓ Zkopírováno!';
								setTimeout(function () { btn.textContent = 'Kopírovat do schránky'; }, 2000);
							}).catch(function () {
								fallbackCopy(text, btn);
							});
						} else {
							fallbackCopy(text, btn);
						}
					});
					function fallbackCopy(text, btn) {
						var textarea = document.createElement('textarea');
						textarea.value = text;
						textarea.style.position = 'fixed';
						textarea.style.opacity = '0';
						document.body.appendChild(textarea);
						textarea.select();
						try {
							document.execCommand('copy');
							btn.textContent = '✓ Zkopírováno!';
							setTimeout(function () { btn.textContent = 'Kopírovat do schránky'; }, 2000);
						} catch (e) {
							btn.textContent = '✗ Nepodařilo se zkopírovat';
							setTimeout(function () { btn.textContent = 'Kopírovat do schránky'; }, 2000);
						}
						document.body.removeChild(textarea);
					}
				</script>
			</div>
		</div>

		{* Nahrání odpovědi *}
		{if !$run->getProcessedAt()}
			<div class="bg-white shadow-sm rounded-lg border border-blue-200 overflow-hidden mb-6">
				<div class="px-6 py-4 border-b border-blue-200 bg-blue-50">
					<h2 class="text-lg font-semibold text-blue-900">Nahrání odpovědi z AI</h2>
				</div>
				<div class="px-6 py-4">
					<form n:name="responseForm" class="space-y-4">
						<div>
							<label n:name="rawResponse" class="block text-sm font-medium text-gray-700 mb-1">JSON odpověď</label>
							<textarea n:name="rawResponse" rows="10" class="shadow-xs focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md font-mono"></textarea>
						</div>
						<div>
							<button n:name="submit" class="inline-flex items-center px-4 py-2 border border-transparent shadow-xs text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
								Zpracovat odpověď
							</button>
						</div>
					</form>
				</div>
			</div>
		{/if}

		{* Výsledky analýzy *}
		{if $run->getProcessedAt()}
			{* Přehled trhu *}
			{if $run->getMarketOverviewSummary()}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-indigo-50 to-blue-50">
						<div class="flex items-center justify-between">
							<h2 class="text-lg font-semibold text-gray-900">🌍 Přehled trhu</h2>
							{if $run->getMarketOverviewSentiment()}
								{if $run->getMarketOverviewSentiment()->value === 'bullish'}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">
										📈 Bullish
									</span>
								{elseif $run->getMarketOverviewSentiment()->value === 'bearish'}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">
										📉 Bearish
									</span>
								{else}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-gray-100 text-gray-800 ring-1 ring-inset ring-gray-300">
										➡️ Neutrální
									</span>
								{/if}
							{/if}
						</div>
					</div>
 				<div class="px-6 py-4">
						<p class="text-sm text-gray-700 leading-relaxed">{$run->getMarketOverviewSummary()}</p>
					</div>
					{if $run->getMarketOverviewGeopoliticalContext()}
						<div class="px-6 py-4 border-t border-gray-200 bg-gradient-to-r from-red-50 to-orange-50">
							<h3 class="text-sm font-semibold text-gray-900 mb-2">⚠️ Geopolitický kontext</h3>
							<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getMarketOverviewGeopoliticalContext()}</p>
						</div>
					{/if}
				</div>
			{/if}

			{if $run->getDailyBriefSummary() || $run->getDailyBriefPortfolioImpactSummary() || $run->getDailyBriefWatchlistSummary()}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-cyan-50 to-sky-50">
						<div class="flex items-center justify-between gap-4">
							<h2 class="text-lg font-semibold text-gray-900">⚡ Denní briefing</h2>
							{if $run->getDailyBriefActionNeeded()}
								{if $run->getDailyBriefActionNeeded()->value === 'none'}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">✅ Bez akce</span>
								{elseif $run->getDailyBriefActionNeeded()->value === 'monitor'}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">👀 Monitorovat</span>
								{elseif $run->getDailyBriefActionNeeded()->value === 'review_positions'}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">📉 Prověřit pozice</span>
								{else}
									<span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold bg-purple-100 text-purple-800 ring-1 ring-inset ring-purple-300">👀 Prověřit watchlist</span>
								{/if}
							{/if}
						</div>
					</div>
					<div class="px-6 py-5 space-y-4">
						{if $run->getDailyBriefSummary()}
							<div>
								<h3 class="text-sm font-semibold text-gray-900 mb-2">Souhrn posledních 24 hodin</h3>
								<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefSummary()}</p>
							</div>
						{/if}

						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							{if $run->getDailyBriefMarketPulse()}
								<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
									<h3 class="text-sm font-semibold text-gray-900 mb-2">🌍 Co hýbalo trhem</h3>
									<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefMarketPulse()}</p>
								</div>
							{/if}
							{if $run->getDailyBriefPortfolioImpactSummary()}
								<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
									<h3 class="text-sm font-semibold text-gray-900 mb-2">📊 Dopad na portfolio</h3>
									<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefPortfolioImpactSummary()}</p>
								</div>
							{/if}
							{if $run->getDailyBriefWatchlistSummary()}
								<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
									<h3 class="text-sm font-semibold text-gray-900 mb-2">👀 Watchlist</h3>
									<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefWatchlistSummary()}</p>
								</div>
							{/if}
							{if $run->getDailyBriefImportantAlerts()}
								<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
									<h3 class="text-sm font-semibold text-gray-900 mb-2">⚠️ Důležitá upozornění</h3>
									<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefImportantAlerts()}</p>
								</div>
							{/if}
						</div>

						{if $run->getDailyBriefNextDaysChecklist()}
							<div class="rounded-lg bg-sky-50 border border-sky-200 p-4">
								<h3 class="text-sm font-semibold text-gray-900 mb-2">🗓️ Checklist na další 1–3 dny</h3>
								<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getDailyBriefNextDaysChecklist()}</p>
							</div>
						{/if}
					</div>
				</div>
			{/if}


 		{* Zhodnocení portfolia *}
			{if $run->getPortfolioEvaluationSummary()}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-emerald-50 to-teal-50">
						<h2 class="text-lg font-semibold text-gray-900">📋 Zhodnocení portfolia</h2>
					</div>
					<div class="px-6 py-4">
						<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getPortfolioEvaluationSummary()}</p>
					</div>
					{if $run->getPortfolioPerformance7DaysSummary()}
						<div class="px-6 py-4 border-t border-gray-200 bg-gradient-to-r from-cyan-50 to-blue-50">
							<h3 class="text-sm font-semibold text-gray-900 mb-2">📈 Výkonnost portfolia za posledních 7 dní</h3>
							<p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{$run->getPortfolioPerformance7DaysSummary()}</p>
						</div>
					{/if}
				</div>
			{/if}

 		{* Rychlý souhrn *}
			{if count($portfolioResults) > 0 || count($watchlistResults) > 0}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
						<h2 class="text-lg font-semibold text-gray-900">📝 Rychlý souhrn doporučení</h2>
					</div>
					<div class="px-6 py-4">
						{if count($portfolioResults) > 0}
							<div class="mb-3">
								<h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Portfolio</h3>
								<div class="flex flex-wrap gap-2">
									{foreach $portfolioResults as $result}
										<a href="#analysis-{$result->getId()}" class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm hover:bg-gray-50 transition-colors">
											<span class="font-medium text-gray-900">{$result->getStockAsset()->getTicker()}</span>
											{if $result->getActionSuggestion()}
												{if $result->getActionSuggestion()->value === 'add_more'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">📈 Přikoupit</span>
												{elseif $result->getActionSuggestion()->value === 'consider_buying'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">🛒 Zvážit nákup</span>
												{elseif $result->getActionSuggestion()->value === 'consider_selling'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800">📉 Zvážit prodej</span>
												{elseif $result->getActionSuggestion()->value === 'hold'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">✊ Držet</span>
												{elseif $result->getActionSuggestion()->value === 'watch_closely'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-800">👁️ Sledovat</span>
												{elseif $result->getActionSuggestion()->value === 'wait'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">⏳ Vyčkat</span>
												{elseif $result->getActionSuggestion()->value === 'not_interesting'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">❌ Nezajímavé</span>
												{/if}
											{/if}
										</a>
									{/foreach}
								</div>
							</div>
						{/if}
						{if count($watchlistResults) > 0}
							<div>
								<h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Watchlist</h3>
								<div class="flex flex-wrap gap-2">
									{foreach $watchlistResults as $result}
										<a href="#analysis-{$result->getId()}" class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm hover:bg-gray-50 transition-colors">
											<span class="font-medium text-gray-900">{$result->getStockAsset()->getTicker()}</span>
											{if $result->getActionSuggestion()}
												{if $result->getActionSuggestion()->value === 'add_more'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">📈 Přikoupit</span>
												{elseif $result->getActionSuggestion()->value === 'consider_buying'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800">🛒 Zvážit nákup</span>
												{elseif $result->getActionSuggestion()->value === 'consider_selling'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800">📉 Zvážit prodej</span>
												{elseif $result->getActionSuggestion()->value === 'hold'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-800">✊ Držet</span>
												{elseif $result->getActionSuggestion()->value === 'watch_closely'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-800">👁️ Sledovat</span>
												{elseif $result->getActionSuggestion()->value === 'wait'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">⏳ Vyčkat</span>
												{elseif $result->getActionSuggestion()->value === 'not_interesting'}
													<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-800">❌ Nezajímavé</span>
												{/if}
											{/if}
										</a>
									{/foreach}
								</div>
							</div>
						{/if}
					</div>
				</div>
			{/if}

			{* Single Stock výsledky *}
			{if count($singleStockResults) > 0}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-orange-50 to-amber-50">
						<h2 class="text-lg font-semibold text-gray-900">📊 Analýza akcie</h2>
					</div>
					<div class="divide-y divide-gray-100">
						{foreach $singleStockResults as $result}
							<div class="px-6 py-5">
								<div class="flex items-center justify-between mb-4">
									<h3 class="text-xl font-bold text-gray-900">
										{$result->getStockName()}
										<span class="ml-2 text-base font-medium text-gray-500">({$result->getStockTicker()})</span>
									</h3>
									{if $result->getActionSuggestion()}
										{if $result->getActionSuggestion()->value === 'add_more' || $result->getActionSuggestion()->value === 'consider_buying'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">
												{if $result->getActionSuggestion()->value === 'add_more'}📈 Přikoupit{else}🛒 Zvážit nákup{/if}
											</span>
										{elseif $result->getActionSuggestion()->value === 'consider_selling'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">
												📉 Zvážit prodej
											</span>
										{elseif $result->getActionSuggestion()->value === 'hold'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-800 ring-1 ring-inset ring-blue-300">
												✊ Držet
											</span>
										{elseif $result->getActionSuggestion()->value === 'watch_closely'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">
												👁️ Sledovat
											</span>
										{elseif $result->getActionSuggestion()->value === 'wait'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-700 ring-1 ring-inset ring-gray-300">
												⏳ Vyčkat
											</span>
										{elseif $result->getActionSuggestion()->value === 'not_interesting'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-300">
												❌ Nezajímavé
											</span>
										{/if}
									{/if}
								</div>

								<div class="space-y-4">
									{* Business Summary *}
									{if $result->getBusinessSummary()}
										<div>
											<h4 class="text-sm font-semibold text-gray-900 mb-1">Popis byznysu</h4>
											<p class="text-sm text-gray-700 leading-relaxed">{$result->getBusinessSummary()}</p>
										</div>
									{/if}

									{* Grid for other sections *}
									<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
										{if $result->getMoatAnalysis()}
											<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
												<h4 class="text-sm font-semibold text-gray-900 mb-2">🏰 Moat (Konkurenční výhoda)</h4>
												<p class="text-sm text-gray-700 leading-relaxed">{$result->getMoatAnalysis()}</p>
											</div>
										{/if}
										{if $result->getFinancialHealth()}
											<div class="rounded-lg bg-gray-50 border border-gray-200 p-4">
												<h4 class="text-sm font-semibold text-gray-900 mb-2">💰 Finanční zdraví</h4>
												<p class="text-sm text-gray-700 leading-relaxed">{$result->getFinancialHealth()}</p>
											</div>
										{/if}
   							{if $result->getGrowthCatalysts()}
   								<div class="rounded-lg bg-gray-50 border-l-3 border-l-green-500 border border-gray-200 p-4">
   									<h4 class="text-sm font-semibold text-gray-900 mb-2">🚀 Růstové katalyzátory</h4>
   									<p class="text-sm text-gray-700 leading-relaxed">{$result->getGrowthCatalysts()}</p>
   								</div>
   							{/if}
   							{if $result->getRisks()}
   								<div class="rounded-lg bg-gray-50 border-l-3 border-l-red-500 border border-gray-200 p-4">
   									<h4 class="text-sm font-semibold text-gray-900 mb-2">⚠️ Rizika</h4>
   									<p class="text-sm text-gray-700 leading-relaxed">{$result->getRisks()}</p>
   								</div>
   							{/if}
  								</div>

  								{if $result->getEarningsCommentary()}
   								<div class="rounded-lg bg-gray-50 border-l-3 border-l-amber-500 border border-gray-200 p-4">
   									<h4 class="text-sm font-semibold text-gray-900 mb-2">📋 Poslední výsledky</h4>
   									<p class="text-sm text-gray-700 leading-relaxed">{$result->getEarningsCommentary()}</p>
   								</div>
  								{/if}

  								{if $result->getDividendAnalysis()}
   								<div class="rounded-lg bg-gray-50 border-l-3 border-l-emerald-500 border border-gray-200 p-4">
   									<h4 class="text-sm font-semibold text-gray-900 mb-2">💵 Dividendová analýza</h4>
   									<p class="text-sm text-gray-700 leading-relaxed">{$result->getDividendAnalysis()}</p>
   								</div>
  								{/if}

 								{* Valuation *}
 								{if $result->getValuationAssessment() || $result->getFairPrice()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-blue-500 border border-gray-200 p-4">
 										<h4 class="text-sm font-semibold text-gray-900 mb-2">📊 Ocenění</h4>
 										{if $result->getValuationAssessment()}
 											<p class="text-sm text-gray-700 leading-relaxed">{$result->getValuationAssessment()}</p>
 										{/if}
 										{if $result->getFairPrice()}
 											<div class="mt-3 pt-2 border-t border-blue-200 flex items-center">
 												<span class="text-sm font-medium text-gray-700 mr-2">Odhadovaná férová cena:</span>
 												<span class="text-base font-bold text-blue-800">
 													{$result->getFairPrice()|currency:$result->getFairPriceCurrency()}
 												</span>
 											</div>
 										{/if}
 									</div>
 								{/if}

 								{* Conclusion *}
 								{if $result->getConclusion()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-indigo-500 border border-gray-200 p-4">
 										<h4 class="text-sm font-semibold text-gray-900 mb-2">💡 Závěr</h4>
 										<p class="text-sm text-gray-700 leading-relaxed">{$result->getConclusion()}</p>
 									</div>
 								{/if}
								</div>
							</div>
						{/foreach}
					</div>
				</div>
			{/if}

			{* Portfolio výsledky *}
			{if count($portfolioResults) > 0}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-cyan-50">
						<h2 class="text-lg font-semibold text-gray-900">💼 Portfolio</h2>
						<p class="text-sm text-gray-500 mt-1">Analýza otevřených pozic</p>
					</div>
					<div class="divide-y divide-gray-100">
						{foreach $portfolioResults as $result}
							<div id="analysis-{$result->getId()}" class="px-6 py-5 hover:bg-gray-50 transition-colors">
								<div class="flex items-center justify-between mb-3">
									<h3 class="text-base font-semibold text-gray-900">
										{$result->getStockAsset()->getName()}
										<span class="ml-2 text-sm font-medium text-gray-500">({$result->getStockAsset()->getTicker()})</span>
									</h3>
									{if $result->getActionSuggestion()}
										{if $result->getActionSuggestion()->value === 'add_more' || $result->getActionSuggestion()->value === 'consider_buying'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">
												{if $result->getActionSuggestion()->value === 'add_more'}📈 Přikoupit{else}🛒 Zvážit nákup{/if}
											</span>
										{elseif $result->getActionSuggestion()->value === 'consider_selling'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">
												📉 Zvážit prodej
											</span>
										{elseif $result->getActionSuggestion()->value === 'hold'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-800 ring-1 ring-inset ring-blue-300">
												✊ Držet
											</span>
										{elseif $result->getActionSuggestion()->value === 'watch_closely'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">
												👁️ Sledovat
											</span>
										{elseif $result->getActionSuggestion()->value === 'wait'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-700 ring-1 ring-inset ring-gray-300">
												⏳ Vyčkat
											</span>
										{elseif $result->getActionSuggestion()->value === 'not_interesting'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-300">
												❌ Nezajímavé
											</span>
										{/if}
									{/if}
								</div>

 							<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
									{if $result->getPositiveNews()}
										<div class="rounded-lg bg-gray-50 border-l-3 border-l-green-500 border border-gray-200 p-3">
											<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">✅ Pozitiva</div>
											<p class="text-sm text-gray-600 leading-relaxed">{$result->getPositiveNews()}</p>
										</div>
									{/if}

									{if $result->getNegativeNews()}
										<div class="rounded-lg bg-gray-50 border-l-3 border-l-red-500 border border-gray-200 p-3">
											<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">⚠️ Negativa</div>
											<p class="text-sm text-gray-600 leading-relaxed">{$result->getNegativeNews()}</p>
										</div>
									{/if}

									{if $result->getInterestingNews()}
										<div class="rounded-lg bg-gray-50 border-l-3 border-l-amber-500 border border-gray-200 p-3">
											<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">💡 Zajímavosti</div>
											<p class="text-sm text-gray-600 leading-relaxed">{$result->getInterestingNews()}</p>
										</div>
									{/if}

  							{if $result->getAiOpinion()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-indigo-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">🤖 Názor AI</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getAiOpinion()}</p>
 									</div>
 								{/if}
 								{if $result->getEarningsCommentary()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-amber-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">📋 Poslední výsledky</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getEarningsCommentary()}</p>
 									</div>
 								{/if}
 								{if $result->getDividendAnalysis()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-emerald-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">💵 Dividendová analýza</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getDividendAnalysis()}</p>
 									</div>
 								{/if}
 								{if $result->getPerformance1DayComment()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-cyan-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">⚡ Výkonnost za 1 den</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getPerformance1DayComment()}</p>
 									</div>
 								{/if}
 								{if $result->getPerformance7DaysComment()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-cyan-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">📈 Výkonnost za 7 dní</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getPerformance7DaysComment()}</p>
 									</div>
 								{/if}
 								</div>

 								{if $result->getConfidenceLevel()}
 									<div class="mt-3 flex items-center">
 										<span class="text-sm font-medium text-gray-700 mr-2">Míra jistoty:</span>
 										{if $result->getConfidenceLevel()->value === 'high'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">Vysoká</span>
 										{elseif $result->getConfidenceLevel()->value === 'medium'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">Střední</span>
 										{else}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">Nízká</span>
 										{/if}
 									</div>
 								{/if}

 								{if $result->getFairPrice()}
									<div class="mt-3 rounded-lg bg-blue-50 border border-blue-200 p-3 flex items-center">
										<span class="text-sm font-medium text-gray-700 mr-2">💰 Odhadovaná férová cena:</span>
										<span class="text-base font-bold text-blue-800">
											{$result->getFairPrice()|currency:$result->getFairPriceCurrency()}
										</span>
									</div>
								{/if}
							</div>
						{/foreach}
					</div>
				</div>
			{/if}

			{* Watchlist výsledky *}
			{if count($watchlistResults) > 0}
				<div class="bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden mb-6">
					<div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-purple-50 to-pink-50">
						<h2 class="text-lg font-semibold text-gray-900">👀 Watchlist</h2>
						<p class="text-sm text-gray-500 mt-1">Sledované akcie</p>
					</div>
					<div class="divide-y divide-gray-100">
						{foreach $watchlistResults as $result}
							<div id="analysis-{$result->getId()}" class="px-6 py-5 hover:bg-gray-50 transition-colors">
								<div class="flex items-center justify-between mb-3">
									<h3 class="text-base font-semibold text-gray-900">
										{$result->getStockAsset()->getName()}
										<span class="ml-2 text-sm font-medium text-gray-500">({$result->getStockAsset()->getTicker()})</span>
									</h3>
									{if $result->getActionSuggestion()}
										{if $result->getActionSuggestion()->value === 'consider_buying'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">
												🛒 Zvážit nákup
											</span>
										{elseif $result->getActionSuggestion()->value === 'watch_closely'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">
												👁️ Sledovat
											</span>
										{elseif $result->getActionSuggestion()->value === 'wait'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-700 ring-1 ring-inset ring-gray-300">
												⏳ Vyčkat
											</span>
										{elseif $result->getActionSuggestion()->value === 'not_interesting'}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-gray-100 text-gray-500 ring-1 ring-inset ring-gray-300">
												❌ Nezajímavé
											</span>
										{else}
											<span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-800 ring-1 ring-inset ring-blue-300">
												{$result->getActionSuggestion()->value}
											</span>
										{/if}
									{/if}
								</div>

 							<div class="space-y-3">
									{if $result->getNews()}
										<div class="rounded-lg bg-gray-50 border-l-3 border-l-blue-500 border border-gray-200 p-3">
											<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">📰 Novinky</div>
											<p class="text-sm text-gray-600 leading-relaxed">{$result->getNews()}</p>
										</div>
									{/if}

  							{if $result->getReasoning()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-indigo-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">💭 Zdůvodnění</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getReasoning()}</p>
 									</div>
 								{/if}
 								{if $result->getEarningsCommentary()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-amber-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">📋 Poslední výsledky</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getEarningsCommentary()}</p>
 									</div>
 								{/if}
 								{if $result->getDividendAnalysis()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-emerald-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">💵 Dividendová analýza</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getDividendAnalysis()}</p>
 									</div>
 								{/if}
 								{if $result->getPerformance1DayComment()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-cyan-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">⚡ Výkonnost za 1 den</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getPerformance1DayComment()}</p>
 									</div>
 								{/if}
 								{if $result->getPerformance7DaysComment()}
 									<div class="rounded-lg bg-gray-50 border-l-3 border-l-cyan-500 border border-gray-200 p-3">
 										<div class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-1">📈 Výkonnost za 7 dní</div>
 										<p class="text-sm text-gray-600 leading-relaxed">{$result->getPerformance7DaysComment()}</p>
 									</div>
 								{/if}
 								</div>

 								{if $result->getConfidenceLevel()}
 									<div class="mt-3 flex items-center">
 										<span class="text-sm font-medium text-gray-700 mr-2">Míra jistoty:</span>
 										{if $result->getConfidenceLevel()->value === 'high'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">Vysoká</span>
 										{elseif $result->getConfidenceLevel()->value === 'medium'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">Střední</span>
 										{else}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">Nízká</span>
 										{/if}
 									</div>
 								{/if}

 								{if $result->getFairPrice()}
 									<div class="mt-3 rounded-lg bg-blue-50 border border-blue-200 p-3 flex items-center">
 										<span class="text-sm font-medium text-gray-700 mr-2">💰 Odhadovaná férová cena:</span>
 										<span class="text-base font-bold text-blue-800">
 											{$result->getFairPrice()|currency:$result->getFairPriceCurrency()}
 										</span>
 									</div>
 								{/if}
 							</div>
						{/foreach}
					</div>
				</div>
			{/if}
		{/if}
	{/if}
{/block}
