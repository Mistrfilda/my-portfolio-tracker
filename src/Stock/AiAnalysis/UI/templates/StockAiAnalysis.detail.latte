 										<span class="text-sm font-medium text-gray-700 mr-2">Míra jistoty:</span>
 										{if $result->getConfidenceLevel()->value === 'high'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 ring-1 ring-inset ring-green-300">Vysoká</span>
 										{elseif $result->getConfidenceLevel()->value === 'medium'}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-800 ring-1 ring-inset ring-amber-300">Střední</span>
 										{else}
 											<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-red-100 text-red-800 ring-1 ring-inset ring-red-300">Nízká</span>
 										{/if}
 									</div>
 								{/if}

 								{if $result->getFairPrice()}
 									<div class="mt-3 rounded-lg bg-blue-50 border border-blue-200 p-3 flex items-center">
 										<span class="text-sm font-medium text-gray-700 mr-2">💰 Odhadovaná férová cena:</span>
 										<span class="text-base font-bold text-blue-800">
 											{$result->getFairPrice()|currency:$result->getFairPriceCurrency()}
 										</span>
 									</div>
 								{/if}
 							</div>
						{/foreach}
					</div>
				</div>
			{/if}
			{/if}
		{/if}
	{/if}
{/block}

{define actionBadge App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum|null $action, bool $compact}
	<span n:class="'inline-flex shrink-0 items-center rounded-full font-medium ring-1 ring-inset',
		$compact ? 'px-2 py-0.5 text-xs' : 'px-2.5 py-1 text-xs',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::ADD_MORE ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::CONSIDER_BUYING ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::CONSIDER_SELLING ? 'bg-rose-50 text-rose-700 ring-rose-600/20',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::HOLD ? 'bg-blue-50 text-blue-700 ring-blue-600/20',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::WATCH_CLOSELY ? 'bg-amber-50 text-amber-700 ring-amber-600/20',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::WAIT ? 'bg-gray-100 text-gray-700 ring-gray-600/10',
		$action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::NOT_INTERESTING || $action === null ? 'bg-gray-100 text-gray-600 ring-gray-600/10'">
		{if $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::ADD_MORE}Přikoupit
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::CONSIDER_BUYING}Zvážit nákup
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::CONSIDER_SELLING}Zvážit prodej
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::HOLD}Držet
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::WATCH_CLOSELY}Sledovat
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::WAIT}Vyčkat
		{elseif $action === App\Stock\AiAnalysis\StockAiAnalysisActionSuggestionEnum::NOT_INTERESTING}Nezajímavé
		{else}Bez doporučení{/if}
	</span>
{/define}

{define confidenceBadge App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum|null $confidence}
	{if $confidence !== null}
		<span n:class="'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset',
			$confidence === App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum::HIGH ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
			$confidence === App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum::MEDIUM ? 'bg-amber-50 text-amber-700 ring-amber-600/20',
			$confidence === App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum::LOW ? 'bg-rose-50 text-rose-700 ring-rose-600/20'">
			Jistota: {if $confidence === App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum::HIGH}vysoká{elseif $confidence === App\Stock\AiAnalysis\StockAiAnalysisConfidenceLevelEnum::MEDIUM}střední{else}nízká{/if}
		</span>
	{/if}
{/define}

{define resultTypeLabel App\Stock\AiAnalysis\StockAiAnalysisResultTypeEnum $type}
	{if $type === App\Stock\AiAnalysis\StockAiAnalysisResultTypeEnum::PORTFOLIO}Portfolio
	{elseif $type === App\Stock\AiAnalysis\StockAiAnalysisResultTypeEnum::WATCHLIST}Watchlist
	{else}Samostatná analýza{/if}
{/define}

{define sentimentBadge string $sentiment}
	<span n:class="'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset',
		$sentiment === 'positive' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$sentiment === 'negative' ? 'bg-rose-50 text-rose-700 ring-rose-600/20',
		$sentiment === 'mixed' ? 'bg-amber-50 text-amber-700 ring-amber-600/20',
		$sentiment === 'neutral' ? 'bg-gray-100 text-gray-600 ring-gray-600/10'">
		{if $sentiment === 'positive'}Pozitivní{elseif $sentiment === 'negative'}Negativní{elseif $sentiment === 'mixed'}Smíšený dopad{else}Neutrální{/if}
	</span>
{/define}

{define riskImpactBadge string $impact}
	<span n:class="'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium',
		$impact === 'high' ? 'bg-rose-50 text-rose-700',
		$impact === 'medium' ? 'bg-amber-50 text-amber-700',
		$impact === 'low' ? 'bg-gray-100 text-gray-600'">
		{if $impact === 'high'}Vysoký dopad{elseif $impact === 'medium'}Střední dopad{else}Nízký dopad{/if}
	</span>
{/define}

{define valuationBadge string $assessment}
	<span n:class="'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset',
		$assessment === 'undervalued' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$assessment === 'fairly_valued' ? 'bg-blue-50 text-blue-700 ring-blue-600/20',
		$assessment === 'overvalued' ? 'bg-rose-50 text-rose-700 ring-rose-600/20',
		$assessment === 'uncertain' ? 'bg-gray-100 text-gray-600 ring-gray-600/10'">
		{if $assessment === 'undervalued'}Podhodnocená{elseif $assessment === 'fairly_valued'}Férově oceněná{elseif $assessment === 'overvalued'}Nadhodnocená{else}Nejisté ocenění{/if}
	</span>
{/define}

{define marketSentimentBadge string $sentiment}
	<span n:class="'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset',
		$sentiment === 'bullish' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$sentiment === 'bearish' ? 'bg-rose-50 text-rose-700 ring-rose-600/20',
		$sentiment === 'neutral' ? 'bg-gray-100 text-gray-600 ring-gray-600/10'">
		{if $sentiment === 'bullish'}Růstový{elseif $sentiment === 'bearish'}Poklesový{else}Neutrální{/if}
	</span>
{/define}

{define directionBadge string $direction}
	<span n:class="'inline-flex shrink-0 items-center rounded-full px-2 py-0.5 text-xs font-medium',
		$direction === 'positive' ? 'bg-emerald-50 text-emerald-700',
		$direction === 'negative' ? 'bg-rose-50 text-rose-700',
		$direction === 'mixed' ? 'bg-amber-50 text-amber-700',
		$direction === 'neutral' ? 'bg-gray-100 text-gray-600'">
		{if $direction === 'positive'}Pozitivní{elseif $direction === 'negative'}Negativní{elseif $direction === 'mixed'}Smíšený dopad{else}Neutrální{/if}
	</span>
{/define}

{define priorityBadge string $priority}
	<span n:class="'inline-flex shrink-0 items-center rounded-full px-2 py-0.5 text-xs font-medium',
		$priority === 'high' ? 'bg-rose-50 text-rose-700',
		$priority === 'medium' ? 'bg-amber-50 text-amber-700',
		$priority === 'low' ? 'bg-gray-100 text-gray-600'">
		{if $priority === 'high'}Vysoká{elseif $priority === 'medium'}Střední{else}Nízká{/if}
	</span>
{/define}

{define dailyActionBadge string $action}
	<span n:class="'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset',
		$action === 'none' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20',
		$action === 'monitor' ? 'bg-amber-50 text-amber-700 ring-amber-600/20',
		$action === 'review_positions' ? 'bg-rose-50 text-rose-700 ring-rose-600/20',
		$action === 'review_watchlist' ? 'bg-purple-50 text-purple-700 ring-purple-600/20'">
		{if $action === 'none'}Bez akce{elseif $action === 'monitor'}Sledovat{elseif $action === 'review_positions'}Prověřit pozice{else}Prověřit watchlist{/if}
	</span>
{/define}
